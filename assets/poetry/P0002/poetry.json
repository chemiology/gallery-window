[
  {
    "title": "가슴 아픈 꽃",
    "image": "images/001.jpg",
    "text": [
      "이른 아침, 온 우주가",
      "봄비에 젖을 때",
      "문득 한 조각 추억이"
    ],
    "audio": "audio/001.mp3"
  },

  {
    "title": "말하지 못한 이야기",
    "image": "images/002.jpg",
    "text": [
      "우리의 서글픈 사연은",
      "당신의 눈물 속에 조용히 잠들어 있고",
      "은빛 어둠이 내려앉은 밤"
    ],
    "audio": "audio/002.mp3"
  },

  {
    "title": "그대의 향기",
    "image": "images/003.jpg",
    "text": [
      "그대의 향기는",
      "그 자리에 조용히 머물러 있고",
      "그대의 체온은"
    ],
    "audio": "audio/003.mp3"
  },


  {
    "title": "기다림",
    "image": "images/004.jpg",
    "text": [
      "나는 오늘도",
      "주소 없는 편지를",
      "우체통에 넣는다"
    ],
    "audio": "audio/004.mp3"
  },


  {
    "title": "어느 가을날",
    "image": "images/005.jpg",
    "text": [
      "어느 가을날",
      "문득, 말로 다할 수 없는 외로움이 스며듭니다",
      "등받이에 몸을 기댄 채"
    ],
    "audio": "audio/005.mp3"
  },


  {
    "title": "그리움",
    "image": "images/006.jpg",
    "text": [
      "눈을 감으면",
      "당신 얼굴이 물안개처럼 번져오다",
      "멀어질수록"
    ],
    "audio": "audio/006.mp3"
  },


  {
    "title": "춤추는 꼭두각시",
    "image": "images/007.jpg",
    "text": [
      "팽팽한 실에 이끌려",
      "양손을 번갈아 흔들고",
      "어깨춤이 절로 흥겨워질 즈음"
    ],
    "audio": "audio/007.mp3"
  }


]
