[
  {
    "title": "고요한 아침의 햇살",
    "image": "images/001.jpg",
    "text": [
      "소복이 쌓인 눈 위로",
      "가만히 햇살이 내려앉습니다",
      "숨죽인 채 반짝이는 눈부심 속을"
    ],
    "audio": "audio/001.mp3"
  },

  {
    "title": "초록의 계곡",
    "image": "images/002.jpg",
    "text": [
      "8월의 초록이 계곡의 옷고름을 풀고",
      "차가운 물길에 살포시 입 맞출 즈음",
      "수줍은 오리 두 마리 눈 맞아"
    ],
    "audio": "audio/002.mp3"
  },

  {
    "title": "아름다운 노래",
    "image": "images/003.jpg",
    "text": [
      "초록 잎에 맺힌 이슬",
      "고요한 아침 햇살을 머금고",
      "반짝입니다"
    ],
    "audio": "audio/003.mp3"
  },


  {
    "title": "세상에 하나뿐인 노래",
    "image": "images/004.jpg",
    "text": [
      "폭풍이 몰아치고",
      "비바람이 스쳐가도",
      "늙은 느티나무는 묵묵히"
    ],
    "audio": "audio/004.mp3"
  },


  {
    "title": "가을의 시선",
    "image": "images/005.jpg",
    "text": [
      "짙푸른 하늘 아래",
      "붉게 타오르는 잎새 하나",
      "바람결에 흔들릴 때"
    ],
    "audio": "audio/005.mp3"
  },


  {
    "title": "겨울의 동반자",
    "image": "images/006.jpg",
    "text": [
      "당신의 맑고 흰 숨결은",
      "내 눈가에 스며",
      "눈부시게 빛납니다"
    ],
    "audio": "audio/006.mp3"
  },


  {
    "title": "심연의 아바타",
    "image": "images/007.jpg",
    "text": [
      "검푸른 심연",
      "그 깊은 곳에 손을 뻗어",
      "너를 스치면"
    ],
    "audio": "audio/007.mp3"
  }


]
