[
  {
    "title": "붉은 태양이 뜰 때",
    "image": "images/001.jpg",
    "text": [
      "새해 첫 아침",
      "한옥 처마 끝을 울리는 종소리처럼",
      "맑은 햇살이 내린다"
    ],
    "audio": "audio/001.mp3"
  },

  {
    "title": "새벽 바다",
    "image": "images/002.jpg",
    "text": [
      "태양이 떠오르기 전",
      "새벽 바다는 깊은 침묵에 잠겨 있다",
      "그 침묵을 가르는 파도 소리가"
    ],
    "audio": "audio/002.mp3"
  },

  {
    "title": "마흔의 능선에서",
    "image": "images/003.jpg",
    "text": [
      "마흔의 언덕에 서서",
      "뒤돌아보니, 참 멀리도 왔구나",
      "스무 살의 낭만은"
    ],
    "audio": "audio/003.mp3"
  },


  {
    "title": "지천명",
    "image": "images/004.jpg",
    "text": [
      "지천명이 어느 메쯤인가",
      "문득 뒤돌아보니",
      "먼 발자국들이 저만치 흩어져 있구나"
    ],
    "audio": "audio/004.mp3"
  },


  {
    "title": "세상이 나를 속일지라도",
    "image": "images/005.jpg",
    "text": [
      "짙푸른 하늘 아래",
      "붉게 타오르는 잎새 하나",
      "바람결에 흔들릴 때"
    ],
    "audio": "audio/005.mp3"
  },


  {
    "title": "이것이 인생이다",
    "image": "images/006.jpg",
    "text": [
      "세상이 나를 속일지라도",
      "나는 눈물을",
      "서둘러 닦지 않으렵니다"
    ],
    "audio": "audio/006.mp3"
  },


  {
    "title": "나무로 살고 싶다",
    "image": "images/007.jpg",
    "text": [
      "서녘 끝에서 밀려오는",
      "검은 발걸음에",
      "겨울의 흔적이 산산이 흩어진다"
    ],
    "audio": "audio/007.mp3"
  }


]
